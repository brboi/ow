{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Instance With Debug",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/{{ main_repo_alias }}",
      "program": "odoo-bin",
      "justMyCode": false,
      "args": {{ vars.debug_args | default(["--dev=all", "--with-demo"]) | tojson }},
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "env": {
        "ODOO_RC": "${workspaceFolder}/odoorc",
        "PYDEVD_DISABLE_FILE_VALIDATION": "1",
        "PYTHON_PATH": "${workspaceFolder}/{{ main_repo_alias }}"
      }
    },
    {
      "name": "Debug Tests ({{ ws_name }})",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/{{ main_repo_alias }}",
      "program": "odoo-bin",
      "justMyCode": false,
      "args": {{ vars.debug_test_args | default(["--test-tags=" ~ ws_name]) | tojson }},
      "python": "${workspaceFolder}/.venv/bin/python",
      "pythonArgs": ["-Xfrozen_modules=off"],
      "env": {
        "ODOO_RC": "${workspaceFolder}/odoorc",
        "PYDEVD_DISABLE_FILE_VALIDATION": "1",
        "PYTHON_PATH": "${workspaceFolder}/{{ main_repo_alias }}"
      }
    }
  ]
}
