# ow.toml - will be automatically copied from ow.toml.example
# when you first run `ow`. You can then edit it to set your own defaults.

# [vars] — optional: inject variables into Jinja2 templates.
# Use {{ vars.key | default(fallback) }} in your templates.
# [vars]
# http_port = 8070
# db_host = "localhost"
# db_port = 5432
# db_user = "odoo"
# db_password = "odoo"
# admin_passwd = "Password"
# smtp_server = "mailpit" # uncomment if you use the mailpit service
# smtp_port = 1025 # uncomment if you use the mailpit service

# You can configure your remotes like this:
#
# [remotes]
# ngram-addons.origin.url = "git@github.com:ngram/odoo-addons.git" # origin is the local remote name
# ngram-addons.trumpet.url = "git@github.com:ngram-trumpet/odoo-addons.git" # and so is trumpet
#
# Then you will be able to use them in a [workspace.repo] section.
#
# e.g.
#   ngram-addons = "main" # origin is always assumed
#   ngram-extra = "trumpet/master"
#

# Official Odoo repositories.
[remotes]
community.origin.url = "git@github.com:odoo/odoo.git"
community.dev.url = "git@github.com:odoo-dev/odoo.git"
community.dev.pushurl = "git@github.com:odoo-dev/odoo.git"
community.dev.fetch = "+refs/heads/*:refs/remotes/dev/*"

# enterprise.origin.url = "git@github.com:odoo/enterprise.git"
# enterprise.dev.url = "git@github.com:odoo-dev/enterprise.git"
# enterprise.dev.pushurl = "git@github.com:odoo-dev/enterprise.git"
# enterprise.dev.fetch = "+refs/heads/*:refs/remotes/dev/*"

# Declare your workspaces with [[workspace]] sections:
#
# [[workspace]]
# name = "opw-123456" # give it a name that suits you (required)
# repo.community = "master..master-opw-123456-ngram"
# repo.enterprise = "origin/master"
# vars.http_port = 8080 # per-workspace override
#
# Use the double dots notation to specify the rebase source branch.
# When a rebase source branch is specified, ow will create a local branch
# with the second part of the name and attach the related worktree to that
# branch.
# It will also make `ow rebase` command aware of the source rebase branch.
#
# Note that without the double dots notation the worktree will be detached.
# Also, specifying the remote is optional but in case of branch naming
# conflict within multiple remotes, it is required to disambiguate.
#
# The following syntax is also valid thanks to the TOML specs:
#
# [[workspace]]
# name = "opw-123456"
#
# [workspace.repo]
# community = "master..master-opw-123456-ngram"
# enterprise = "origin/master"
#
# [workspace.vars]
# http_port = 8080
#
